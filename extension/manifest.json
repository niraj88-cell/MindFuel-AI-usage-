{
  "manifest_version": 3,
  "name": "SatyaShift — Ambient Focus",
  "version": "2.0.0",
  "description": "Passive, domain-only attention tracking. Zero manual logging, ever.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://satyashift.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SatyaShift"
  }
}
